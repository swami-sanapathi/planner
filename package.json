{
  "name": "kids-study-planner",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "oxlint src --tsconfig tsconfig.json --vitest-plugin",
    "lint:fix": "oxlint src --tsconfig tsconfig.json --vitest-plugin --fix",
    "format": "oxfmt src angular.json package.json tsconfig.json tsconfig.app.json tsconfig.spec.json AGENTS.md README.md .prettierrc .oxfmtrc.json .oxlintrc.json .vscode --write",
    "format:check": "oxfmt src angular.json package.json tsconfig.json tsconfig.app.json tsconfig.spec.json AGENTS.md README.md .prettierrc .oxfmtrc.json .oxlintrc.json .vscode --check"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
